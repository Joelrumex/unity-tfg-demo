  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6c77e9a88f082234bbbf7adb4ad401a6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EndingSceneManager
  endingType: 0
  canvasGroup: {fileID: 485030952}
  titleText: {fileID: 356796412}
  bodyText: {fileID: 1341316651}
  statsText: {fileID: 123389070}
  newGameButton: {fileID: 224412289}
  backgroundImage: {fileID: 1730084113}
  pacifistBackgroundColor: {r: 0.85, g: 0.95, b: 1, a: 1}
  pacifistTitleColor: {r: 0.3, g: 0.6, b: 1, a: 1}
  pacifistTitle: True Pacifist
  pacifistBody: "You walked through war and chose not to become it.\n\nEvery enemy
    you faced, you offered something rarer than victory.\n\nYou offered them a way
    out.\n\nThe forest breathes again.\nThe knight remembers her name.\nAnd the Red
    Sister \u2014 for the first time \u2014 is quiet."
  genocideBackgroundColor: {r: 0.1, g: 0.05, b: 0.05, a: 1}
  genocideTitleColor: {r: 0.8, g: 0.1, b: 0.1, a: 1}
  genocideTitle: No Mercy
  genocideBody: 'You had every chance to stop.


    The mage held a seed in his
    hand.

    The knight just wanted her back.

    Even she, at the end, was tired.


    You
    gave none of them the chance to find out

    what came after the anger.


    The
    war is over.

    But so is everything else.'
  battleResult: {fileID: 0}
  mainMenuScene: MainMenu
  fadeInDuration: 2
  textRevealDelay: 0.5
