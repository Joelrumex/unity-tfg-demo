  m_Name: Mage_Phase2_SitDowm
  m_EditorClassIdentifier: Assembly-CSharp::ActOption
  actionName: Sit Down
  phase: 1
  dialogueLines:
  - '"You sit down on the charred ground next to him."'
  - '"No words. Just presence."'
  completionDialogueLines:
  - '"The mage stares at you for a long moment."'
  - '"Then, slowly, he sits too."'
  - '"''There were silver birches here,'' he says quietly. ''Hundreds of them.''"'
  - '"''They burned in a single night.''"'
