  m_Script: {fileID: 11500000, guid: 8f4d6abb1ebe6524ab0a990e616f544e, type: 3}
  m_Name: Mage_observe
  m_EditorClassIdentifier: Assembly-CSharp::ObserveOption
  phase1Hints:
  - '"His eyes dart around nervously, like he''s expecting an attack."'
  - '"He''s clutching something tightly in his fist... a seed, maybe?"'
  - '"He doesn''t want to fight. He wants to be heard."'
  - '"Try acknowledging where you are. Show him you see the forest."'
  phase2Hints:
  - '"His grip on the seed has loosened."'
  - '"He keeps glancing at a burned tree behind him."'
  - '"He''s starting to listen, but he doesn''t trust words yet."'
  - "\"Maybe share in his grief. Don't try to fix it \u2014 just feel it with him.\"\n"
  phase3Hints:
  - '"His shoulders have dropped. The fire in his eyes is dimming."'
  - '"He''s looking at you differently now. Less like a threat."'
  - '"He needs to know the forest won''t be forgotten."'
  - '"Make a promise. Mean it."'
