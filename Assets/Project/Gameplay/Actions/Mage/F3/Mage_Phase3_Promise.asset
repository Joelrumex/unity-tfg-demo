  m_Name: Mage_Phase3_Promise
  m_EditorClassIdentifier: Assembly-CSharp::ActOption
  actionName: 'Make a Promise '
  phase: 2
  dialogueLines:
  - '"''I''ll remember this place,'' you tell him. ''What it was. What it could be
    again.''"'
  - '"He opens his hand. The seed is still there, impossibly green."'
  completionDialogueLines:
  - '"A long silence."'
  - '"''Remembering isn''t enough,'' he says."'
  - '"Then, softer: ''But it''s a start.''"'
  - '"He plants the seed in the ash."'
  - '"The fighting is over."'
