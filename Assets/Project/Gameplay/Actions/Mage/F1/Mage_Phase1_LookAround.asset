  actionName: 'Look Around '
  phase: 0
  dialogueLines:
  - '"You slowly look around at the charred trees and ash-covered ground."'
  - '"You don''t say anything. You just look."'
  completionDialogueLines:
  - '"The mage watches you carefully."'
  - '"''You actually see it,'' he mutters. ''Most of them never even look.''"'
  - '"Something in his posture shifts."'
