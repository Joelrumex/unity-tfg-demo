  m_Script: {fileID: 11500000, guid: 8416df98839a14341a3c026f8168a930, type: 3}
  m_Name: Knight_Phase2_AskAboutLocket
  m_EditorClassIdentifier: Assembly-CSharp::ActOption
  actionName: Ask About the Locket
  phase: 1
  dialogueLines:
  - '"''The locket,'' you say carefully. ''Who''s inside it?''"

'
  - '"His sword hand drops an inch."'
  - '"''None of your...'' He stops."'
  completionDialogueLines:
  - '"He opens it himself. You don''t ask to see."'
  - '"''She used to laugh at my terrible jokes,'' he says."'
  - '"''Every single one. Even the awful ones.''"'
  - '"He closes it again. His jaw is tight."'
  - '"''She''s gone because of this war. Because of people like you.''"'
  - '"''...and people like me,'' he adds, barely audible."'
  mercyGain: 34
  requiredUses: 3
  useCount: 0
