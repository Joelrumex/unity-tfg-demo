  m_Script: {fileID: 11500000, guid: 8416df98839a14341a3c026f8168a930, type: 3}
  m_Name: Knight_Phase2_SayYouKnow
  m_EditorClassIdentifier: Assembly-CSharp::ActOption
  actionName: '"I Know"'
  phase: 1
  dialogueLines:
  - '"''I know,'' you say. No explanation. No defense."'
  - '"He stares at you."'
  - '"''You don''t know anything.''"'
  - '"''I know you''re exhausted,'' you say."'
  completionDialogueLines:
  - '"The sword lowers slightly."'
  - '"''...Yeah,'' he says finally. ''Yeah, I am.''"'
  - '"It''s the most honest thing he''s said."'
