  m_Script: {fileID: 11500000, guid: 8416df98839a14341a3c026f8168a930, type: 3}
  m_Name: RedSister_Phase3_Silence
  m_EditorClassIdentifier: Assembly-CSharp::ActOption
  actionName: Say Nothing
  phase: 2
  dialogueLines:
  - '"You say nothing."'
  - '"She fills the silence with words, then threats, then nothing."'
  - '"You wait."'
  completionDialogueLines:
  - '"''Stop it,'' she says."'
  - '"You keep waiting."'
  - "\"'I said stop\u2014' Her voice cracks.\""
  - '"The silence stretches until it becomes something else entirely."'
  - '"Something neither of you has a word for.'
  - '"She sits down on the floor."'
  - '"Just sits."'
  - '"''I''m so tired,'' she says."'
  - '"It''s the most human thing she''s ever said."'
  - '"''I know,'' you say."'
  - "\"And the battle \u2014 somehow \u2014 is over.\""
  mercyGain: 34
  requiredUses: 3
  useCount: 0
