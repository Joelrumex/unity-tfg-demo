  m_Script: {fileID: 11500000, guid: 8416df98839a14341a3c026f8168a930, type: 3}
  m_Name: RedSister_Phase3_NameHer
  m_EditorClassIdentifier: Assembly-CSharp::ActOption
  actionName: Use Her Real Name
  phase: 2
  dialogueLines:
  - '"You use her real name. The one from before."'
  - '"The air changes."'
  - "\"Her composure fractures \u2014 just for a moment.\""
  - '"''Where did you hear that,'' she says. Not a question."'
  completionDialogueLines:
  - '"''He told me,'' you say. ''He never stopped saying it.''"'
  - '"Something moves across her face. You can''t name it."'
  - '"''He''s an idiot,'' she says."'
  - '"''He loves you,'' you say."'
  - '"''That''s the same thing,'' she whispers."'
  - '"But the fire in her eyes has dimmed to an ember."'
  mercyGain: 34
  requiredUses: 1
  useCount: 0
