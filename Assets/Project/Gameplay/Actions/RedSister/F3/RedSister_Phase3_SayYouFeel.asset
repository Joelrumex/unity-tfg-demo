  m_Script: {fileID: 11500000, guid: 8416df98839a14341a3c026f8168a930, type: 3}
  m_Name: RedSister_Phase3_SayYouFeel
  m_EditorClassIdentifier: Assembly-CSharp::ActOption
  actionName: '"I Feel It Too"'
  phase: 2
  dialogueLines:
  - '"''I feel it too,'' you tell her. ''The anger. The loss. All of it.''"'
  - '"''Then why aren''t you burning?'' she demands."'
  - '"''Because I chose not to,'' you say."'
  completionDialogueLines:
  - '"''Chose,'' she repeats. Like it''s a foreign word."'
  - '"''You think you chose. The fire chooses for you.''"'
  - '"''Maybe,'' you admit. ''But I keep choosing again. Every time.''"'
  - '"The ember flickers."'
  - '"''Every time?'' she asks."'
  - '"''Every single time,'' you say."'
  - '"She looks away first."'
  - '"That has never happened before."'
  mercyGain: 34
  requiredUses: 2
  useCount: 0
