  m_Script: {fileID: 11500000, guid: 8416df98839a14341a3c026f8168a930, type: 3}
  m_Name: RedSister_Phase2_AskWhatSheWants
  m_EditorClassIdentifier: Assembly-CSharp::ActOption
  actionName: Ask What She Wants
  phase: 1
  dialogueLines:
  - '"''What do you actually want?'' you ask."'
  - '"She opens her mouth. Closes it."'
  - '"''To feel everything,'' she says finally. ''And for everything to feel.''"'
  completionDialogueLines:
  - '"''Even if they don''t want to?'' you ask."'
  - '"A long pause."'
  - '"''...They would want to,'' she says. ''If they understood'
  - '"''Or maybe,'' you say carefully, ''they feel things you don''t recognize yet.''"'
  - '"Her eyes narrow. But she doesn''t disagree."'
  mercyGain: 34
  requiredUses: 2
  useCount: 0
