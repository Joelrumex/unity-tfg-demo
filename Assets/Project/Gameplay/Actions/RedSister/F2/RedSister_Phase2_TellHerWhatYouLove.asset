  m_Script: {fileID: 11500000, guid: 8416df98839a14341a3c026f8168a930, type: 3}
  m_Name: RedSister_Phase2_TellHerWhatYouLove
  m_EditorClassIdentifier: Assembly-CSharp::ActOption
  actionName: Tell Her What You Love
  phase: 1
  dialogueLines:
  - '"You tell her about something you love."'
  - '"Something real. Something specific."'
  - '"She listens with her head tilted, like an animal hearing a new sound."'
  completionDialogueLines:
  - '"''That''s passion,'' she says slowly."'
  - '"''Yes,'' you say."'
  - '"''Then why don''t you burn for it?'' she demands."'
  - '"''I do,'' you say. ''Just not like you.''"'
  - '"She goes quiet. That answer confused her."'
  - '"Good."'
  mercyGain: 34
  requiredUses: 3
  useCount: 0
